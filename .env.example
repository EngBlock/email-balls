# Copy this file to `.env` and fill in values as needed.
# `.env` is gitignored (see .gitignore) so secrets never enter git history.

# Gravatar API key. Currently only the public, unauthenticated avatar
# endpoint is used (see src/lib/gravatar.ts), so this is reserved for
# future authenticated Gravatar API calls and is optional today.
# Issue one at https://gravatar.com/developers/.
GRAVATAR_API_KEY=

# Optional. Hostname/IP that Vite's dev server binds to so a Tauri
# mobile build on the same LAN can reach it (e.g. 192.168.1.42).
# Read by vite.config.ts. Leave unset for desktop-only development.
# TAURI_DEV_HOST=
